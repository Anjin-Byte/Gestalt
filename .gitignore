apps/gestalt/src/wasm/wasm_renderer/

# ── legacy/apps/web ────────────────────────────────────────────────────────
# wasm output dirs in legacy have their own per-directory .gitignore (*).
# dist is not tracked for the legacy app.
legacy/apps/web/dist
legacy/apps/web/.vite
legacy/apps/web/playwright-report
legacy/apps/web/test-results

# ── Rust ───────────────────────────────────────────────────────────────────
target
**/target

# ── Design docs / vault (local only, not published) ───────────────────────
docs/
memory/

