{
  "name": "gestalt",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "pnpm -C apps/gestalt dev",
    "dev:legacy": "pnpm -C legacy/apps/web dev",
    "dev:legacy:full": "pnpm build:wasm:legacy && pnpm dev:legacy",
    "build": "pnpm -C apps/gestalt build",
    "build:legacy": "pnpm -C legacy/apps/web build",
    "build:legacy:full": "pnpm build:wasm:legacy && pnpm build:legacy",
    "build:wasm": "./scripts/build-wasm.sh gestalt",
    "build:wasm:legacy": "./scripts/build-wasm.sh legacy",
    "build:wasm:all": "./scripts/build-wasm.sh all",
    "preview": "pnpm -C apps/gestalt preview",
    "preview:legacy": "pnpm -C legacy/apps/web preview",
    "test": "pnpm -C apps/gestalt test",
    "test:e2e": "pnpm -C apps/gestalt test:e2e"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69"
  }
}
